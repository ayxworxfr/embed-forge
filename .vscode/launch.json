{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "EmbedForge: Debug current host test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-host/test/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "EmbedForge: build current host test",
            "osx": {
                "MIMode": "lldb"
            },
            "linux": {
                "MIMode": "gdb",
                "miDebuggerPath": "${config:embed-forge.gdbPath}",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            },
            "windows": {
                "MIMode": "gdb",
                "miDebuggerPath": "${config:embed-forge.gdbPath}",
                "program": "${workspaceFolder}/build-host/test/${fileBasenameNoExtension}.exe",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            }
        },
        {
            "name": "EmbedForge: Debug test_cli",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-host/test/test_cli",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "EmbedForge: host build",
            "osx": {
                "MIMode": "lldb"
            },
            "linux": {
                "MIMode": "gdb",
                "miDebuggerPath": "${config:embed-forge.gdbPath}",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            },
            "windows": {
                "MIMode": "gdb",
                "miDebuggerPath": "${config:embed-forge.gdbPath}",
                "program": "${workspaceFolder}/build-host/test/test_cli.exe",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            }
        }
    ]
}
