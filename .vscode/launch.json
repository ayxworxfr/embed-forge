{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "EmbedForge: Debug current host target",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-host/test/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "EmbedForge: build current host target",
            "osx": {
                "MIMode": "lldb"
            },
            "linux": {
                "MIMode": "gdb",
                "miDebuggerPath": "/usr/bin/gdb",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            },
            "windows": {
                "MIMode": "gdb",
                // 标准 MSYS2 安装改 C:/msys64/mingw64/bin/gdb.exe
                "miDebuggerPath": "C:/software/common/msys64/mingw64/bin/gdb.exe",
                "program": "${workspaceFolder}/build-host/test/${fileBasenameNoExtension}.exe",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            }
        }
    ]
}
