{
    "configurations": [
        {
            "name": "EmbedForge",
            "compileCommands": "${workspaceFolder}/build-host/compile_commands.json",
            "includePath": [
                "${workspaceFolder}/osal/include",
                "${workspaceFolder}/osal/freertos/config",
                "${workspaceFolder}/third_party/freertos_kernel/include",
                "${workspaceFolder}/third_party/freertos_kernel/portable/GCC/ARM_CM4F",
                "${workspaceFolder}/third_party/cmsis_core/CMSIS/Core/Include",
                "${workspaceFolder}/third_party/cmsis_device_f4/Include",
                "${workspaceFolder}/board/nucleo_f411re",
                "${workspaceFolder}/third_party/stm32f4xx_hal_driver/Inc",
                "${workspaceFolder}/lib/ef_common/include",
                "${workspaceFolder}/lib/ringbuffer/include",
                "${workspaceFolder}/driver",
                "${workspaceFolder}/driver/device",
                "${workspaceFolder}/hal/include",
                "${workspaceFolder}/service/log/include",
                "${workspaceFolder}/service/cli/include",
                "${workspaceFolder}/service/config/include",
                "${workspaceFolder}/service/event_bus/include",
                "${workspaceFolder}/app"
            ],
            "defines": [
                "STM32F411xE",
                "EF_ENABLE_AUTO_INIT"
            ],
            "compilerPath": "/usr/bin/clang",
            "compilerArgs": [
                "--target=arm-none-eabi"
            ],
            "cStandard": "c11",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}
